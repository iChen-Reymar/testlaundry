# Copy to .env for local dev (do NOT commit .env)
# For Vercel: add the same variables in Project → Settings → Environment Variables, then REDEPLOY

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key

# Find both values in Supabase Dashboard → Project Settings → API
# - Project URL  →  VITE_SUPABASE_URL
# - Publishable key (or anon public key)  →  VITE_SUPABASE_PUBLISHABLE_KEY
